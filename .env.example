# ============================================================
# WordPress 管理者設定
# ============================================================
# このファイルを .env にコピーしてから、値を設定してください。
#
#   cp .env.example .env
#
# ⚠️ .env はGitにコミットされません（.gitignoreで除外済み）

# 管理者ユーザー名
WP_ADMIN_USER=admin

# 管理者パスワード（必ず変更してください）
WP_ADMIN_PASSWORD=your-password-here

# 管理者メールアドレス（必ず変更してください）
WP_ADMIN_EMAIL=your-email@example.com

# サイトタイトル（自由に変更できます）
WP_SITE_TITLE="AI Coding Lab"

# サイトURL（通常は変更不要）
WP_SITE_URL=http://localhost
